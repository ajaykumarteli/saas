    "category": "User Signup",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /signup"
      },
      {
        "type": "action",
        "description": "Fill \"new.user+e2e1@example.com\" into the email input field"
      },
      {
        "type": "action",
        "description": "Fill \"StrongPass!234\" into the password input field"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Strong\" is visible"
      },
      {
        "type": "action",
        "description": "Fill \"StrongPass!234\" into the confirm password input field"
      },
      {
        "type": "action",
        "description": "Click the Create Account button to submit"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Free\" is visible"
      }
    ]
  },
